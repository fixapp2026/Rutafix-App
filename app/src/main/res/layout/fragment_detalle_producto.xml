<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 1. Encabezado Superior -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_detail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@android:drawable/ic_menu_revert">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-black"
            android:text="@string/product_detail_title"
            android:textColor="@color/azul_profundo"
            android:textSize="18sp" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_container"
        app:layout_constraintTop_toBottomOf="@id/toolbar_detail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- 2. Imagen Principal -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_margin="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/iv_detail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/logo"
                    android:contentDescription="@string/desc_logo_app" />
            </androidx.cardview.widget.CardView>

            <!-- 3. Bloque de Información Principal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg">

                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/nombre_del_producto"
                    android:textColor="@color/azul_profundo"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tv_detail_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/marca"
                    android:textColor="@color/azul_claro"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_detail_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/_0_000_cop"
                    android:textColor="@color/naranja"
                    android:textSize="22sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/spacing_lg"
                    android:background="@color/gris_claro" />

                <!-- 4. Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/product_description_label"
                    android:textColor="@color/azul_profundo"
                    android:textSize="@dimen/text_medium" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="4sp"
                    android:text="@string/este_es_un_producto_de_alta_calidad_dise_ado_para_mejorar_el_rendimiento_de_tu_veh_culo_fabricado_con_materiales_resistentes_y_duraderos"
                    android:textColor="@color/gris"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 5. Acciones Principales (Barra Inferior Fija) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_action_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_cart_detail"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_button_primary"
                android:fontFamily="sans-serif-medium"
                android:text="@string/product_add_to_cart"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_buy_now"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@color/naranja"
                android:fontFamily="sans-serif-medium"
                android:text="@string/product_buy_now"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>