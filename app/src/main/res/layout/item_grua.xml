<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_lg"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F4F8">
            <ImageView
                android:id="@+id/iv_grua_foto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="@color/azul_oscuro"
                android:contentDescription="Icono de grúa" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_grua_tipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Tipo de Grúa"
                android:textColor="@color/azul_profundo"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_grua_capacidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Capacidad"
                android:textColor="#757575"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_grua_tiempo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tiempo estimado"
                android:textColor="@color/azul_claro"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_grua_precio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Precio"
                android:textColor="@color/naranja"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_seleccionar_grua"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="12dp"
            android:text="Pedir"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>