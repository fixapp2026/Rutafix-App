<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical"
    android:padding="@dimen/spacing_sm">

    <TextView
        android:id="@+id/tv_home_titulo_tienda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_sm"
        android:fontFamily="sans-serif-black"
        android:text="@string/cat_logo_de_productos_rutafix"
        android:textColor="@color/azul_profundo"
        android:textSize="22sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_home_catalogo_automotriz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_lg" />

</LinearLayout>