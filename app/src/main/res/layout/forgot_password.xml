<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_lg">

        <!-- 1. Encabezado Superior -->
        <LinearLayout
            android:id="@+id/header_container_forgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_forgot_logo"
                android:layout_width="@dimen/logo_size"
                android:layout_height="@dimen/logo_size"
                android:contentDescription="@string/desc_logo_app"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/app_name"
                android:textColor="@color/azul_oscuro"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 2. Bloque de Título e Instrucción -->
        <LinearLayout
            android:id="@+id/title_container_forgot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/header_container_forgot">

            <TextView
                android:id="@+id/tv_forgot_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/forgot_title"
                android:textColor="@color/azul_profundo"
                android:textSize="@dimen/text_heading"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tv_forgot_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="@string/forgot_subtitle"
                android:textColor="@color/gris_claro"
                android:textSize="@dimen/text_body"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- 3. Apoyo Visual Discreto -->
        <ImageView
            android:id="@+id/iv_forgot_support"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:src="@android:drawable/ic_dialog_email"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_container_forgot"
            app:tint="@color/azul_claro" />

        <!-- 4. Campo Principal: Correo -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_forgot_email"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:hint="@string/email_hint"
            app:boxStrokeColor="@color/azul_oscuro"
            app:hintTextColor="@color/azul_oscuro"
            app:layout_constraintTop_toBottomOf="@id/iv_forgot_support"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="@color/azul_oscuro">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_forgot_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 5. Botón Principal -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_send_recovery"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="sans-serif-medium"
            android:text="@string/btn_send"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_medium"
            app:layout_constraintTop_toBottomOf="@id/til_forgot_email" />

        <!-- 6. Acción Secundaria: Volver al login -->
        <TextView
            android:id="@+id/tv_back_to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="sans-serif-black"
            android:padding="12dp"
            android:text="@string/back_login"
            android:textColor="@color/azul_oscuro"
            android:textSize="@dimen/text_body"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_send_recovery"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>