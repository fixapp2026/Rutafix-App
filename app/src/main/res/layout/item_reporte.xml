<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_lg"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTipoServicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/servicio_de_gr_a"
                android:textColor="@color/azul_oscuro"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFechaReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_19_abr_2026"
                android:textColor="@color/gris"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvClienteReporte"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/cliente_juan_p_rez"
            android:textColor="@color/azul_profundo"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEstadoReporte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/completado"
                android:textColor="@color/verde"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_120_000_cop"
                android:textColor="@color/negro"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>