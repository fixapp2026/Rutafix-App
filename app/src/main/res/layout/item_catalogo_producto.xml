<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md">

        <!-- Imagen del producto (Respetada) -->
        <ImageView
            android:id="@+id/iv_producto_imagen"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/logo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nombre (Respetado) -->
            <TextView
                android:id="@+id/tv_producto_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/nombre_del_producto"
                android:textColor="@color/azul_profundo"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Marca (Respetada) -->
            <TextView
                android:id="@+id/tv_producto_marca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/marca"
                android:textColor="@color/azul_claro"
                android:textSize="14sp" />

            <!-- Precio (Respetado) -->
            <TextView
                android:id="@+id/tv_producto_precio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/_0_000_cop"
                android:textColor="@color/naranja"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Acción de Agregar -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_producto_agregar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:text="@string/agregar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>