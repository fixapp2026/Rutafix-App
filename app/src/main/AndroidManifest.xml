<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.rutafix">

    <!-- Permisos necesarios para Supabase y conectividad -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rutafix">

        <!-- Splash Screen: Punto de entrada -->
        <activity
            android:name="com.inicio.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad de Bienvenida/Home (Faltaba) -->
        <activity
            android:name="com.inicio.Home"
            android:exported="false"
            android:label="Bienvenido" />

        <!-- Autenticación -->
        <activity
            android:name=".Login"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Registro"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:label="@string/forgot_title" />

        <!-- Actividades Principales del Admin -->
        <activity android:name="com.main.admin.AdminActivity" android:exported="false"/>
        <activity android:name="com.main.admin.AgregarTecnicoActivity" android:exported="false"/>
        <activity android:name="com.main.admin.DetalleReporteActivity" android:exported="false"/>
        <activity android:name="com.main.admin.AdminEditarPerfilActivity" android:exported="false"/>
        <activity android:name="com.main.admin.HistorialTecnicoActivity" android:exported="false"/>
        <activity android:name="com.main.admin.PerfilTecnicoActivity" android:exported="false"/>
        <activity android:name="com.main.MainActivity" android:exported="false" />
    </application>

</manifest>