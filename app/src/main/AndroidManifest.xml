<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.rutafix">

    <!-- Permisos necesarios para Supabase y conectividad -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rutafix">

        <!-- Splash Screen: Punto de entrada corregido -->
        <activity
            android:name="com.inicio.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad de Bienvenida/Home (Faltaba) -->
        <activity
            android:name="com.inicio.Home"
            android:exported="false"
            android:label="Bienvenido" />

        <!-- Autenticación -->
        <activity
            android:name=".Login"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Registro"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:label="@string/forgot_title" />

        <!-- Actividades Principales -->
        <activity
            android:name="com.main.MainActivity"
            android:exported="false"
            android:label="RutaFix" />

        <activity
            android:name="com.main.admin.AdminActivity"
            android:exported="false"
            android:label="Panel de Administrador" />

    </application>

</manifest>